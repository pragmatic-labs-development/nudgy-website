---
---

<section id="download" class="download">
  <div class="container">
    <div class="card">
      <div class="coming-soon-badge">Coming Soon</div>

      <h2>Download Nudgy</h2>
      <p class="subtitle">
        Free to download. No account, no subscription, no nonsense.
      </p>

      <button class="btn-download" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download .dmg
      </button>

      <div class="requirements">
        <div class="req-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="m9 12 2 2 4-4"/></svg>
          macOS 13.0 Ventura or later
        </div>
        <div class="req-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="m9 12 2 2 4-4"/></svg>
          Apple Silicon &amp; Intel
        </div>
        <div class="req-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="m9 12 2 2 4-4"/></svg>
          Free forever
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .download {
    padding: 6rem 1.5rem;
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 500px;
    margin: 0 auto;
    text-align: center;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 3rem 2rem;
    background: var(--surface);
  }

  .coming-soon-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 9999px;
    background: rgba(124, 106, 255, 0.12);
    border: 1px solid rgba(124, 106, 255, 0.3);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .subtitle {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    border-radius: 10px;
    background: var(--accent);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    cursor: not-allowed;
    opacity: 0.4;
    margin-bottom: 2rem;
  }

  .requirements {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: center;
  }

  .req-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .req-item svg {
    color: #444;
    flex-shrink: 0;
  }
</style>
