<style>
  .download {
    padding: 5rem 1.5rem 6rem;
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 440px;
    margin: 0 auto;
    text-align: center;
  }

  .card {
    border: 1px solid rgba(255, 107, 43, 0.14);
    border-radius: 18px;
    padding: 3rem 2.25rem;
    background: var(--surface);
    box-shadow:
      0 0 0 1px rgba(255, 107, 43, 0.04),
      0 24px 60px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 107, 43, 0.08);
  }

  .coming-soon-badge {
    display: inline-block;
    padding: 0.28rem 0.8rem;
    border-radius: 9999px;
    background: rgba(255, 107, 43, 0.1);
    border: 1px solid rgba(255, 107, 43, 0.22);
    color: var(--accent);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  h2 {
    font-size: 1.9rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    margin-bottom: 0.65rem;
    color: var(--text);
  }

  .subtitle {
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 2rem;
    border-radius: 10px;
    background: var(--accent);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    margin-bottom: 2rem;
    letter-spacing: -0.01em;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-download:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
  }

  .requirements {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }

  .req-item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.78rem;
    color: var(--muted);
  }

  .req-item svg {
    color: var(--accent);
    opacity: 0.5;
    flex-shrink: 0;
  }
</style>
