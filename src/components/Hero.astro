---
---

<section class="hero">

  <!-- Background glow -->
  <div class="bg-beam" aria-hidden="true"></div>

  <!-- Left: text -->
  <div class="hero-text">
    <div class="badge">
      <span class="badge-dot" aria-hidden="true"></span>
      Mac App · Free · No Account Required
    </div>

    <h1>
      Annotate Screenshots.<br />
      <span class="accent">Ship Faster.</span>
    </h1>

    <p class="subheadline">
      Capture any part of your screen, annotate it with arrows,
      shapes, and text, then save it locally. All in seconds.
      Built for anyone who moves fast.
    </p>

    <div class="cta-group">
      <a href="https://pub-b7c088e1d92b4658b0f591ae9c5d8b2e.r2.dev/Nudgy-0.1.0.dmg" class="btn-primary" download>
        Download for Mac · Free
      </a>
      <span class="cta-note">macOS 13.0 or later · Apple Silicon &amp; Intel</span>
      <span class="disclaimer">By downloading, you agree to our <a href="/terms">Terms of Use</a>. Provided as-is with no warranty.</span>
    </div>
  </div>

  <!-- Right: mascot -->
  <div class="mascot-col">
    <img src="/assets/kiwi-mascot.png" alt="Nudgy mascot" class="mascot" />
  </div>

  <!-- Scroll cue -->
  <a href="#features-section" class="scroll-cue" aria-label="Scroll to features">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </a>

</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 107, 43, 0); }
    50%       { box-shadow: 0 0 28px 6px rgba(255, 107, 43, 0.22); }
  }
  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 107, 43, 0); }
    50%       { box-shadow: 0 0 0 4px rgba(255, 107, 43, 0.3); }
  }
  @keyframes bounceCue {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50%       { transform: translateY(5px); opacity: 0.8; }
  }

  /* ── Layout ── */
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    align-items: start;
    padding-top: 5vh;
    overflow: hidden;
  }

  /* ── Glow ── */
  .bg-beam {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 140vw;
    height: 120vh;
    background: radial-gradient(ellipse at top center,
      rgba(200, 75, 15, 0.55) 0%,
      rgba(180, 55, 10, 0.2) 35%,
      transparent 60%);
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Left column ── */
  .hero-text {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 14vh clamp(1.5rem, 3vw, 3rem) 3rem clamp(4rem, 9vw, 9rem);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.9rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 107, 43, 0.2);
    background: rgba(255, 107, 43, 0.05);
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    margin-bottom: 1.75rem;
    width: fit-content;
    animation: fadeUp 0.7s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .badge-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    animation: pulseDot 2.5s ease-in-out infinite;
  }

  h1 {
    font-size: clamp(2rem, 3.8vw, 3.8rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--text);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.7s 0.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .accent {
    background: linear-gradient(135deg, #FF6B2B 0%, #FFAA6B 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subheadline {
    font-size: clamp(0.88rem, 1.3vw, 1rem);
    color: var(--muted);
    line-height: 1.8;
    max-width: 380px;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.7s 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .cta-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    animation: fadeUp 0.7s 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 2rem;
    border-radius: 10px;
    background: var(--accent);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .btn-primary {
    animation: pulseGlow 3.5s 1.5s ease-in-out infinite;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 10px 36px var(--accent-glow-strong);
    animation: none;
  }

  .cta-note {
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 0.01em;
  }

  .disclaimer {
    color: #3a3a3a;
    font-size: 0.68rem;
    letter-spacing: 0.01em;
    line-height: 1.5;
  }

  .disclaimer a {
    color: #555;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .disclaimer a:hover {
    color: var(--muted);
  }

  /* ── Right column ── */
  .mascot-col {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: visible;
    animation: fadeIn 1s 0.15s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .mascot-col::before {
    content: '';
    position: absolute;
    width: 55%;
    height: 55%;
    background: radial-gradient(circle, rgba(255, 107, 43, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    top: 42%;
    left: 38%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
  }

  .mascot {
    position: relative;
    z-index: 1;
    max-height: 105vh;
    width: auto;
    max-width: 110%;
    display: block;
    transform: translateX(-14%) translateY(5vh);
    filter: drop-shadow(0 24px 48px rgba(255, 107, 43, 0.22)) drop-shadow(0 4px 16px rgba(0,0,0,0.5));
  }

  /* ── Scroll cue ── */
  .scroll-cue {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: var(--muted);
    text-decoration: none;
    animation: bounceCue 2s ease-in-out infinite;
    transition: color 0.2s;
  }

  .scroll-cue:hover { color: var(--accent); }

  /* ── Mobile ── */
  @media (max-width: 680px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-text {
      padding: 3.5rem 1.5rem 1.5rem;
      align-items: center;
      text-align: center;
    }
    .badge, .subheadline { margin-left: auto; margin-right: auto; }
    .cta-group { align-items: center; }
    .mascot { transform: none; width: 80%; }
    .mascot-col { justify-content: center; min-height: 55vw; }
  }
</style>
