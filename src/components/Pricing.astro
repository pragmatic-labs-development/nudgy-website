---
const tiers = [
  {
    name: 'Free',
    price: { monthly: 0, annualMonthly: 0, annualTotal: 0 },
    description: 'Try it out. No account needed.',
    cta: 'Download Free',
    ctaHref: '#download',
    highlight: false,
    features: [
      { text: '25 screenshots / month', included: true },
      { text: 'Full annotation tools', included: true },
      { text: 'Save locally', included: true },
      { text: 'Expiring links', included: false },
      { text: 'Animated GIFs', included: false },
      { text: 'Cloud storage', included: false },
      { text: 'Always latest version', included: false },
    ],
  },
  {
    name: 'Pro',
    price: { monthly: 4, annualMonthly: 1.99, annualTotal: 23.88 },
    description: 'For individuals who move fast.',
    cta: 'Get Early Access',
    ctaHref: '#',
    highlight: false,
    features: [
      { text: 'Unlimited screenshots', included: true },
      { text: 'Full annotation tools', included: true },
      { text: 'Save locally (unlimited)', included: true },
      { text: '5 expiring links / month (24h)', included: true },
      { text: '5 animated GIFs / month (watermarked)', included: true },
      { text: 'Cloud storage', included: false },
      { text: 'Always latest version', included: true },
    ],
  },
  {
    name: 'Pro+',
    price: { monthly: 9, annualMonthly: 3.99, annualTotal: 48 },
    description: 'For power users and teams.',
    cta: 'Get Early Access',
    ctaHref: '#',
    highlight: true,
    features: [
      { text: 'Unlimited screenshots', included: true },
      { text: 'Full annotation tools', included: true },
      { text: 'Save locally (unlimited)', included: true },
      { text: 'Unlimited links + full expiry control', included: true },
      { text: 'Unlimited GIFs, no watermark', included: true },
      { text: '5 GB cloud storage', included: true },
      { text: 'Always latest version', included: true },
    ],
  },
];
---

<section class="pricing" id="pricing">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">Pricing</p>
      <h2>Simple, honest pricing.</h2>
      <p class="subtext">Free forever for local use. Upgrade when you need more.</p>
    </div>

    <div class="toggle-wrap">
      <span class="toggle-label" id="label-monthly">Monthly</span>
      <button class="toggle" id="billing-toggle" aria-label="Toggle billing period" aria-pressed="false">
        <span class="toggle-knob"></span>
      </button>
      <span class="toggle-label" id="label-annual">
        Annual
        <span class="save-badge">Save up to 55%</span>
      </span>
    </div>

    <div class="grid">
      {tiers.map((tier) => (
        <div class={`card ${tier.highlight ? 'card--highlight' : ''}`}>
          {tier.highlight && <div class="popular-badge">Most Popular</div>}

          <div class="card-header">
            <h3>{tier.name}</h3>
            <p class="tier-description">{tier.description}</p>
          </div>

          <div class="price-wrap">
            <div class="price" data-monthly={tier.price.monthly} data-annual={tier.price.annual}>
              {tier.price.monthly === 0 ? (
                <span class="price-amount">Free</span>
              ) : (
                <>
                  <span class="price-currency">$</span>
                  <span class="price-amount" data-monthly={tier.price.monthly} data-annual={tier.price.annualMonthly}>
                    {tier.price.monthly}
                  </span>
                  <span class="price-period">/mo</span>
                </>
              )}
            </div>
            {!!tier.price.annualTotal && (
              <p class="price-note" data-monthly={`or $${tier.price.annualTotal}/year`} data-annual={`billed as $${tier.price.annualTotal}/year`}>
                or ${tier.price.annualTotal}/year
              </p>
            )}
          </div>

          <a href={tier.ctaHref} class={`btn ${tier.highlight ? 'btn--primary' : 'btn--secondary'} ${tier.ctaHref === '#' ? 'btn--coming-soon' : ''}`}>
            {tier.cta}
          </a>
          {tier.ctaHref === '#' && (
            <p class="cta-note">Available soon · No card required</p>
          )}

          <div class="feature-divider"></div>
          <ul class="feature-list">
            {tier.features.map((feature) => (
              <li class={`feature-item ${feature.included ? '' : 'feature-item--muted'}`}>
                {feature.included ? (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                ) : (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="cross" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                  </svg>
                )}
                {feature.text}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const toggle = document.getElementById('billing-toggle')!;
  const labelMonthly = document.getElementById('label-monthly')!;
  const labelAnnual = document.getElementById('label-annual')!;
  let isAnnual = true;

  function applyBilling(annual: boolean) {
    toggle.setAttribute('aria-pressed', String(annual));
    toggle.classList.toggle('active', annual);
    labelMonthly.classList.toggle('active', !annual);
    labelAnnual.classList.toggle('active', annual);

    document.querySelectorAll<HTMLElement>('.price-amount[data-monthly]').forEach(el => {
      el.classList.add('price-changing');
      setTimeout(() => {
        el.textContent = annual ? el.dataset.annual! : el.dataset.monthly!;
        el.classList.remove('price-changing');
      }, 120);
    });

    document.querySelectorAll<HTMLElement>('.price-note[data-monthly]').forEach(el => {
      el.textContent = annual ? el.dataset.annual! : el.dataset.monthly!;
    });
  }

  // Init to annual
  applyBilling(true);

  toggle.addEventListener('click', () => {
    isAnnual = !isAnnual;
    applyBilling(isAnnual);
  });
</script>

<style>
  .pricing {
    padding: 5rem 1.5rem 6rem;
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(1.7rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.12;
    margin-bottom: 0.85rem;
    color: var(--text);
  }

  .subtext {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* ── Toggle ── */
  .toggle-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .toggle-label {
    font-size: 0.85rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s;
  }

  .toggle-label.active {
    color: var(--text);
  }

  .save-badge {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.5rem;
    border-radius: 9999px;
    background: rgba(255, 107, 43, 0.12);
    border: 1px solid rgba(255, 107, 43, 0.22);
    color: var(--accent);
  }

  .toggle {
    position: relative;
    width: 40px;
    height: 22px;
    border-radius: 9999px;
    background: var(--border);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }

  .toggle.active {
    background: var(--accent);
    border-color: var(--accent);
  }

  .toggle-knob {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .toggle.active .toggle-knob {
    transform: translateX(18px);
  }

  /* ── Grid ── */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .card {
    position: relative;
    background: var(--surface);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    transition: background 0.2s;
  }

  .card:hover {
    background: var(--surface-hover);
  }

  .card--highlight {
    background: linear-gradient(160deg, #1a0e07 0%, #120a04 50%, #0d0d0d 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 107, 43, 0.12),
      0 0 60px rgba(255, 107, 43, 0.06);
  }

  .card--highlight::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #FF6B2B 0%, #FFAA6B 100%);
    box-shadow: 0 0 16px rgba(255, 107, 43, 0.7), 0 0 4px rgba(255, 107, 43, 0.9);
  }

  .card--highlight:hover {
    background: linear-gradient(160deg, #1f1008 0%, #150c05 50%, #0f0f0f 100%);
  }

  .card--highlight .card-header h3 {
    color: #fff;
  }

  .card--highlight .price-amount {
    font-size: 3.4rem;
    background: linear-gradient(135deg, #FF6B2B 0%, #FFAA6B 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card--highlight .price-currency {
    background: linear-gradient(135deg, #FF6B2B 0%, #FFAA6B 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .popular-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(255, 107, 43, 0.1);
    border: 1px solid rgba(255, 107, 43, 0.22);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
  }

  .card-header {
    margin-bottom: 1.5rem;
  }

  .card-header h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .tier-description {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ── Price ── */
  .price-wrap {
    margin-bottom: 1.5rem;
  }

  .price {
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
    margin-bottom: 0.35rem;
  }

  .price-currency {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    align-self: flex-start;
    margin-top: 0.4rem;
  }

  .price-amount {
    font-size: 2.8rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--text);
    line-height: 1;
  }

  .price-period {
    font-size: 0.85rem;
    color: var(--muted);
    margin-left: 0.1rem;
  }

  .price-note {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .cta-note {
    font-size: 0.72rem;
    color: #555;
    text-align: center;
    margin-top: -1rem;
    margin-bottom: 1.25rem;
  }

  .feature-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: 1.25rem;
  }

  @keyframes priceChange {
    0% { opacity: 1; transform: translateY(0); }
    50% { opacity: 0; transform: translateY(-4px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .price-changing {
    animation: priceChange 0.24s ease-in-out;
  }

  /* ── CTA ── */
  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.25rem;
    border-radius: 9px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    margin-bottom: 1.75rem;
    transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.15s;
  }

  .btn--primary {
    background: linear-gradient(135deg, #FF6B2B 0%, #FF8A4C 100%);
    color: #fff;
    box-shadow: 0 4px 24px rgba(255, 107, 43, 0.3);
  }

  .btn--primary:hover {
    background: linear-gradient(135deg, #FF7A3A 0%, #FF9A5C 100%);
    box-shadow: 0 6px 32px rgba(255, 107, 43, 0.45);
    transform: translateY(-1px);
  }

  .btn--secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn--secondary:hover {
    border-color: rgba(255, 107, 43, 0.3);
    color: var(--text);
  }

  .btn--coming-soon {
    opacity: 0.65;
    cursor: default;
    pointer-events: none;
  }

  /* ── Features ── */
  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.4;
  }

  .feature-item--muted {
    color: #444;
  }

  .check {
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .cross {
    color: #333;
    flex-shrink: 0;
    margin-top: 1px;
  }

  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
