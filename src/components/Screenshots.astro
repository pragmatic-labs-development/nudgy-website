---
---

<section class="screenshots">
  <div class="container">
    <div class="section-header">
      <h2>See it in action</h2>
      <p>Capture, annotate, done.</p>
    </div>

    <div class="window-grid">
      <!-- Main large screenshot -->
      <div class="mac-window large">
        <div class="titlebar">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="window-title">Nudgy : Annotation</span>
        </div>
        <div class="screenshot-area">
          <div class="placeholder-content">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="placeholder-icon"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            <p>Screenshot coming soon</p>
            <span>Drop your annotated screenshot here</span>
          </div>
        </div>
      </div>

      <!-- Two smaller screenshots stacked -->
      <div class="side-stack">
        <div class="mac-window small">
          <div class="titlebar">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="window-title">Nudgy : Capture</span>
          </div>
          <div class="screenshot-area">
            <div class="placeholder-content small">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="placeholder-icon"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
              <p>Capture mode</p>
            </div>
          </div>
        </div>

        <div class="mac-window small">
          <div class="titlebar">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="window-title">Nudgy : Tools</span>
          </div>
          <div class="screenshot-area">
            <div class="placeholder-content small">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="placeholder-icon"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
              <p>Annotation toolbar</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <p class="screenshot-note">Screenshots will be added before launch</p>
  </div>
</section>

<style>
  .screenshots {
    padding: 6rem 1.5rem;
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .section-header p {
    color: var(--muted);
    font-size: 1.05rem;
  }

  .window-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .mac-window {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
  }

  .titlebar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    background: #161616;
    border-bottom: 1px solid var(--border);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green  { background: #28c841; }

  .window-title {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 500;
  }

  .screenshot-area {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mac-window.large .screenshot-area {
    min-height: 360px;
  }

  .mac-window.small .screenshot-area {
    min-height: 160px;
  }

  .placeholder-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    padding: 2rem;
  }

  .placeholder-content.small {
    gap: 0.35rem;
    padding: 1.25rem;
  }

  .placeholder-icon {
    color: #333;
    margin-bottom: 0.25rem;
  }

  .placeholder-content p {
    font-size: 0.88rem;
    font-weight: 500;
    color: #444;
  }

  .placeholder-content span {
    font-size: 0.75rem;
    color: #333;
  }

  .side-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .screenshot-note {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.78rem;
    color: #444;
  }

  @media (max-width: 700px) {
    .window-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
