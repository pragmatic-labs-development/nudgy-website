---
const features = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>`,
    title: 'Capture Anything',
    description: 'Full screen or drag to select any region. Trigger with a global shortcut from anywhere on your Mac.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
    title: 'Annotate Instantly',
    description: 'Arrows, shapes, text, freehand pen — everything you need to mark up a screenshot in seconds.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: 'Stays Local',
    description: 'No cloud, no accounts, no uploads. Your screenshots live on your machine, period.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg>`,
    title: 'Blazing Fast',
    description: 'Trigger, select, annotate, save — the whole flow takes under 10 seconds. Zero friction.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>`,
    title: 'Built for Vibe Coding',
    description: 'Annotate screenshots to feed directly into your AI coding workflows. Built by developers, for developers.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
    title: 'Free, Forever',
    description: 'No subscription, no trial, no paywall. Download it and use it.',
  },
];
---

<section class="features">
  <div class="container">
    <div class="section-header">
      <h2>Everything you need.<br />Nothing you don't.</h2>
      <p>Purpose-built for speed. No bloat, no complexity — just a fast, native Mac experience.</p>
    </div>

    <div class="grid">
      {features.map((f) => (
        <div class="card">
          <div class="icon" set:html={f.icon} />
          <h3>{f.title}</h3>
          <p>{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 6rem 1.5rem;
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .section-header p {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--border);
  }

  .card {
    background: var(--surface);
    padding: 1.75rem;
  }

  .card:hover {
    background: #161616;
  }

  .icon {
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .card p {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 701px) and (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
