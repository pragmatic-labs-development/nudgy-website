---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>`,
    title: 'Capture Anything',
    description: 'Full screen or drag to select any region. Trigger with a global shortcut from anywhere on your Mac.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
    title: 'Annotate Instantly',
    description: 'Arrows, shapes, text, freehand pen. Everything you need to mark up a screenshot in seconds.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: 'Stays Local',
    description: 'No cloud, no accounts, no uploads. Your screenshots live on your machine, period.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg>`,
    title: 'Blazing Fast',
    description: 'Trigger, select, annotate, save. The whole flow takes under 10 seconds. Zero friction.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: 'Built for Vibe Coding',
    description: 'Annotate screenshots and paste them straight into Claude, Cursor, or any AI tool. Show exactly what you mean.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
    title: 'Free, Forever',
    description: 'No subscription, no trial, no paywall. Download it and use it.',
  },
];
---

<section class="features">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">Features</p>
      <h2>Everything you need.<br />Nothing you don't.</h2>
      <p class="subtext">No subscriptions, no cloud, no accounts. Just the fastest way to go from capture to clipboard.</p>
    </div>

    <div class="grid">
      {features.map((f) => (
        <div class="card">
          <div class="icon" set:html={f.icon} />
          <h3>{f.title}</h3>
          <p>{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 5rem 1.5rem 6rem;
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 940px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(1.7rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.12;
    margin-bottom: 0.85rem;
    color: var(--text);
  }

  .subtext {
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 400px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--border);
    gap: 1px;
  }

  .card {
    background: var(--surface);
    padding: 1.75rem;
    transition: background 0.2s;
  }

  .card:hover {
    background: var(--surface-hover);
  }

  .icon {
    color: var(--accent);
    margin-bottom: 1rem;
    transition: filter 0.2s;
  }

  .card:hover .icon {
    filter: drop-shadow(0 0 6px rgba(255, 107, 43, 0.5));
  }

  .card h3 {
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 0.45rem;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .card p {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.65;
  }

  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 641px) and (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
